# AxonHub
# Example: http://localhost:8090 or http://localhost:8090/v1
AXONHUB_BASE_URL=
AXONHUB_API_KEY=

# Dify API / web service
# Example: http://localhost:5001
DIFY_BASE_URL=
DIFY_API_KEY=

# Dify plugin debug / daemon
# Fill these from your Dify plugin debug page or local daemon configuration.
DIFY_PLUGIN_DEBUG_KEY=
DIFY_PLUGIN_DAEMON_URL=

# Optional local path if you install the Dify plugin daemon in this repository.
DIFY_PLUGIN_DAEMON_PATH=.tools/dify-plugin.exe
